/**
 * @section tsconfig: Emitter/Consumer
 * @description Configuracion de ejecucion para Payload CMS con Redireccion de ADN.
 * Protocolo OEDP-V17.0 - Zenith Architecture Standard.
 */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "Preserve",
    "moduleResolution": "bundler",
    "allowJs": true,
    "strict": true,
    "noEmit": false,

    "outDir": "../../dist/out-tsc/apps/content-manager-system",
    "tsBuildInfoFile": "../../dist/out-tsc/apps/content-manager-system/tsconfig.app.tsbuildinfo",

    /**
     * 🛡️ MANIOBRA DE REDIRECCIÓN DE ADN (OEDP-V17.0)
     * La aplicacion consume las firmas fisicas (.d.ts) para evitar TS6059.
     */
    "paths": {
      "@/*": ["src/*"],
      "@floripa-dignidade/exceptions": ["../../dist/out-tsc/libs/core/exceptions/index.d.ts"],
      "@floripa-dignidade/telemetry": ["../../dist/out-tsc/libs/core/telemetry/index.d.ts"],
      "@floripa-dignidade/environment-validator": [
        "../../dist/out-tsc/libs/core/environment-validator/index.d.ts"
      ],
      "@floripa-dignidade/identity": ["../../dist/out-tsc/libs/modules/identity/index.d.ts"]
    },

    "plugins": [
      {
        "name": "next"
      }
    ],

    "types": ["node"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "index.d.ts", "next-env.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "dist", ".next", "**/*.spec.ts", "**/*.test.ts"],
  "references": [
    {
      "path": "../../libs/core/exceptions/tsconfig.lib.json"
    },
    {
      "path": "../../libs/modules/identity/tsconfig.lib.json"
    },
    {
      "path": "../../libs/core/telemetry/tsconfig.lib.json"
    },
    {
      "path": "../../libs/core/environment-validator/tsconfig.lib.json"
    }
  ]
}
