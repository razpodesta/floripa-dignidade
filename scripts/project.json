{
  "name": "@floripa-dignidade/scripts",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "scripts/src",
  "projectType": "library",
  "tags": [
    "scope:tools",
    "type:tool",
    "platform:node"
  ],
  "targets": {
    "internationalization-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx scripts/src/run-weaver.ts",
        "color": true
      },
      "cache": true,
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/libs/**/src/lib/i18n/*.json"
      ],
      "outputs": ["{workspaceRoot}/apps/floripa-dignidade/src/app/i18n/dictionaries/*.json"]
    },
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{workspaceRoot}/dist/out-tsc/scripts"],
      "options": {
        "outputPath": "dist/libs/scripts",
        "main": "scripts/src/run-weaver.ts",
        "tsConfig": "scripts/tsconfig.lib.json",
        "stripLeadingPaths": true
      },
      "cache": true
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/out-tsc/scripts"],
      "options": {
        "command": "tsc -p scripts/tsconfig.lib.json"
      },
      "cache": true
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "cache": true
    }
  }
}
