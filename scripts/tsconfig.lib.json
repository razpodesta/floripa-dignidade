{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc/scripts",
    "tsBuildInfoFile": "../../dist/out-tsc/scripts/tsconfig.lib.tsbuildinfo",

    /* --- INTEGRIDAD SOBERANA (ADN Emitter) --- */
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "rootDir": "src",

    /*
       🛡️ SANEADO Zenith: Redirección de Grafo (Fix TS2307 / TS6059)
       Se erradicó el segmento 'src' de la ruta de salida. Cuando el búnker 'tools'
       emite su ADN, omite la carpeta base. La resolución ahora apunta a la
       verdad física inmutable.
    */
    "paths": {
      "@floripa-dignidade/tools":["../../dist/out-tsc/libs/tools/index.d.ts"]
    },

    /* --- RESOLUCIÓN NEXT-GEN --- */
    "module": "Preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    /* --- ADN DEL ENTORNO (Node.js Scripting Context) --- */
    "types": ["node"],
    "lib": ["ES2022"]
  },
  "include": ["src/**/*.ts"],
  "exclude":[
    "node_modules",
    "dist",
    "out-tsc",
    "../../dist",
    "../../node_modules"
  ]
}
