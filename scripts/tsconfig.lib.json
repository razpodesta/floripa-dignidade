{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /* 🛡️ SANEADO Zenith: Corrección de profundidad de salida (1 nivel arriba) */
    "outDir": "../dist/out-tsc/scripts",
    "tsBuildInfoFile": "../dist/out-tsc/scripts/tsconfig.lib.tsbuildinfo",

    /* --- INTEGRIDAD SOBERANA (ADN Emitter) --- */
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "rootDir": "src",

    /*
       🛡️ SANEADO Zenith: Redirección de Grafo (Fix TS2307 / TS6059)
    */
    "paths": {
      "@floripa-dignidade/tools": ["../dist/out-tsc/libs/tools/index.d.ts"]
    },

    /* --- RESOLUCIÓN NEXT-GEN --- */
    "module": "Preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    /* --- ADN DEL ENTORNO (Node.js Scripting Context) --- */
    "types": ["node"],
    "lib": ["ES2022"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "out-tsc", "../dist", "../node_modules"],
  "references": [
    {
      "path": "../libs/core/exceptions/tsconfig.lib.json"
    },
    {
      "path": "../libs/core/telemetry/tsconfig.lib.json"
    },
    {
      "path": "../libs/tools/tsconfig.lib.json"
    }
  ]
}
