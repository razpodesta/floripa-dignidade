/**
 * @section tsconfig: Emitter
 * @description Generador de ADN (.d.ts) con redireccion fisica de Grafo.
 * Protocolo OEDP-V17.0 - Zenith Architecture Standard.
 */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../dist/out-tsc/scripts",
    "tsBuildInfoFile": "../dist/out-tsc/scripts/tsconfig.lib.tsbuildinfo",

    /* --- Integridad Soberana --- */
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "rootDir": "src",
    "noEmit": false,

    /* --- Redireccion de ADN Maestro (Solucion TS6059 / TS2307) --- */
    "paths": {
      "@floripa-dignidade/tools": ["../dist/out-tsc/libs/tools/index.d.ts"],
      "@floripa-dignidade/telemetry": ["../dist/out-tsc/libs/core/telemetry/index.d.ts"],
      "@floripa-dignidade/exceptions": ["../dist/out-tsc/libs/core/exceptions/index.d.ts"]
    },

    /* --- Resolucion Next-Gen --- */
    "module": "Preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    /* --- ADN del Entorno (Node.js Automation) --- */
    "types": ["node"],
    "lib": ["ES2022"]
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "out-tsc",
    "../dist",
    "../node_modules"
  ],
  "references": [
    { "path": "../libs/core/exceptions/tsconfig.lib.json" },
    { "path": "../libs/core/telemetry/tsconfig.lib.json" },
    { "path": "../libs/tools/tsconfig.lib.json" }
  ]
}
