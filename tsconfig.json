{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    /**
     * 🛡️ ESTRATEGIA GATEKEEPER SUPREMO
     * SANEADO Zenith: Desactivamos 'composite' en la raíz. Este archivo no es
     * un proyecto ejecutable, sino el mapa maestro que coordina el build
     * incremental del enjambre (Solution Mode).
     */
    "composite": false,
    "noEmit": true,
    "ignoreDeprecations": "5.0"
  },

  /* 🛡️ LEY DEL ORQUESTADOR: No compilar nada aquí. Delegación total. */
  "files": [],
  "include": [],
  "exclude": ["node_modules", "tmp", "dist"],

  /**
   * @section Grafo de Referencias Sincronizadas (Project References)
   * Define la jerarquía física de construcción para 'tsc -b'.
   * SANEADO Zenith: Ordenado alfabéticamente por capas para prevención de colisiones.
   */
  "references": [
    /* 🧱 CAPA 1: CIMIENTOS (Core Leaf Nodes) */
    { "path": "./libs/core/analytics" },
    { "path": "./libs/core/communication-providers/resend" },
    { "path": "./libs/core/environment-validator" },
    { "path": "./libs/core/exceptions" },
    { "path": "./libs/core/routing" },
    { "path": "./libs/core/telemetry" },

    /* 🧠 CAPA 2: MOTORES (Cognitive Engines) */
    { "path": "./libs/engines/adversarial-simulation-engine" },
    { "path": "./libs/engines/health-analysis" },
    { "path": "./libs/engines/health-monitor" },
    { "path": "./libs/engines/impact-analytics-engine" },
    { "path": "./libs/engines/search-engine" },

    /* 📦 CAPA 3: DOMINIOS (Business Modules) */
    { "path": "./libs/modules/identity" },
    { "path": "./libs/modules/interaction-engine" },
    { "path": "./libs/modules/messaging-engine" },
    { "path": "./libs/modules/newsletter" },
    { "path": "./libs/modules/pmf-open-data-engine" },
    { "path": "./libs/modules/reputation-engine" },
    { "path": "./libs/modules/social-media" },
    { "path": "./libs/modules/territorial-engine" },
    { "path": "./libs/modules/whatsapp/communication-service" },

    /* 🎨 CAPA 4: FUNDICIÓN VISUAL (Shared Layer) */
    { "path": "./libs/shared" },

    /* 🛠️ CAPA 5: INFRAESTRUCTURA Y QA (Support) */
    { "path": "./libs/tools" },
    { "path": "./scripts" },
    { "path": "./tests" },

    /* 🚀 CAPA 6: CARCASAS (Final Application Shells) */
    { "path": "./apps/content-manager-system" },
    { "path": "./apps/floripa-dignidade" }
  ]
}
