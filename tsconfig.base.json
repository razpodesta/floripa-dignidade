{
  "compilerOptions": {
    /* --- FUNDAMENTOS TÉCNICOS (Modern JS) --- */
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "useDefineForClassFields": true,
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",

    /* --- RESOLUCIÓN ZENITH (Bundler-First Strategy) --- */
    /** 
     * 🛡️ LEY ARQUITECTÓNICA: Usamos 'Preserve' y 'bundler'.
     * Esto indica a TypeScript que un orquestador externo (Turbopack/SWC) manejará 
     * la resolución final, permitiendo rutas limpias sin extensiones .js que rompen Next.js.
     */
    "module": "Preserve",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "resolvePackageJsonExports": true,
    "resolvePackageJsonImports": true,

    /* --- RIGOR DE IDENTIDAD ESM (ADR 0030) --- */
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,

    /* --- ESTRATEGIA DE PROYECTO COMPUESTO (Grafo de Nx) --- */
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,
    "importHelpers": true,
    "skipLibCheck": true,

    /* --- RIGOR DE TIPADO ISO (ISO/IEC 25010) --- */
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,

    /* --- PROTECCIÓN DE ÁMBITO GLOBAL --- */
    "types": ["node"],

    /* --- ESPEJO DE SOBERANÍA (Mapa de Rutas Maestro) --- */
    /* 🛡️ Mejora: Se consolida la resolución hacia los puntos de entrada src/index.ts */
    "paths": {
      /* Layer: CORE */
      "@floripa-dignidade/analytics": ["libs/core/analytics/src/index.ts"],
      "@floripa-dignidade/analytics/*": ["libs/core/analytics/src/*"],
      "@floripa-dignidade/environment-validator": ["libs/core/environment-validator/src/index.ts"],
      "@floripa-dignidade/environment-validator/*": ["libs/core/environment-validator/src/*"],
      "@floripa-dignidade/exceptions": ["libs/core/exceptions/src/index.ts"],
      "@floripa-dignidade/exceptions/*": ["libs/core/exceptions/src/*"],
      "@floripa-dignidade/resend-provider": ["libs/core/communication-providers/resend/src/index.ts"],
      "@floripa-dignidade/resend-provider/*": ["libs/core/communication-providers/resend/src/*"],
      "@floripa-dignidade/routing": ["libs/core/routing/src/index.ts"],
      "@floripa-dignidade/routing/*": ["libs/core/routing/src/*"],
      "@floripa-dignidade/telemetry": ["libs/core/telemetry/src/index.ts"],
      "@floripa-dignidade/telemetry/*": ["libs/core/telemetry/src/*"],

      /* Layer: ENGINES */
      "@floripa-dignidade/adversarial-simulation-engine": ["libs/engines/adversarial-simulation-engine/src/index.ts"],
      "@floripa-dignidade/adversarial-simulation-engine/*": ["libs/engines/adversarial-simulation-engine/src/*"],
      "@floripa-dignidade/health-analysis-engine": ["libs/engines/health-analysis/src/index.ts"],
      "@floripa-dignidade/health-analysis-engine/*": ["libs/engines/health-analysis/src/*"],
      "@floripa-dignidade/health-monitor": ["libs/engines/health-monitor/src/index.ts"],
      "@floripa-dignidade/health-monitor/*": ["libs/engines/health-monitor/src/*"],
      "@floripa-dignidade/impact-analytics-engine": ["libs/engines/impact-analytics-engine/src/index.ts"],
      "@floripa-dignidade/impact-analytics-engine/*": ["libs/engines/impact-analytics-engine/src/*"],
      "@floripa-dignidade/search-engine": ["libs/engines/search-engine/src/index.ts"],
      "@floripa-dignidade/search-engine/*": ["libs/engines/search-engine/src/*"],

      /* Layer: MODULES */
      "@floripa-dignidade/identity": ["libs/modules/identity/src/index.ts"],
      "@floripa-dignidade/identity/*": ["libs/modules/identity/src/*"],
      "@floripa-dignidade/interaction-engine": ["libs/modules/interaction-engine/src/index.ts"],
      "@floripa-dignidade/interaction-engine/*": ["libs/modules/interaction-engine/src/*"],
      "@floripa-dignidade/messaging-engine": ["libs/modules/messaging-engine/src/index.ts"],
      "@floripa-dignidade/messaging-engine/*": ["libs/modules/messaging-engine/src/*"],
      "@floripa-dignidade/newsletter": ["libs/modules/newsletter/src/index.ts"],
      "@floripa-dignidade/newsletter/*": ["libs/modules/newsletter/src/*"],
      "@floripa-dignidade/pmf-open-data-engine": ["libs/modules/pmf-open-data-engine/src/index.ts"],
      "@floripa-dignidade/pmf-open-data-engine/*": ["libs/modules/pmf-open-data-engine/src/*"],
      "@floripa-dignidade/reputation-engine": ["libs/modules/reputation-engine/src/index.ts"],
      "@floripa-dignidade/reputation-engine/*": ["libs/modules/reputation-engine/src/*"],
      "@floripa-dignidade/territorial-engine": ["libs/modules/territorial-engine/src/index.ts"],
      "@floripa-dignidade/territorial-engine/*": ["libs/modules/territorial-engine/src/*"],
      "@floripa-dignidade/whatsapp-communication-service": ["libs/modules/whatsapp/communication-service/src/index.ts"],
      "@floripa-dignidade/whatsapp-communication-service/*": ["libs/modules/whatsapp/communication-service/src/*"],

      /* Layer: SHARED */
      "@floripa-dignidade/shared": ["libs/shared/src/index.ts"],
      "@floripa-dignidade/shared/*": ["libs/shared/src/*"],

      /* Layer: INFRA & SCRIPTS */
      "@floripa-dignidade/qa-mirror": ["tests/src/index.ts"],
      "@floripa-dignidade/scripts": ["scripts/src/index.ts"],
      "@floripa-dignidade/tools": ["libs/tools/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist"]
}