{
  "name": "@floripa-dignidade/tools",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/tools/src",
  "projectType": "library",
  "tags": [
    "scope:tools",
    "type:tool",
    "platform:node"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{workspaceRoot}/dist/libs/tools"],
      "options": {
        "outputPath": "dist/libs/tools",
        "main": "libs/tools/src/index.ts",
        "tsConfig": "libs/tools/tsconfig.lib.json",
        "stripLeadingPaths": true
      },
      "cache": true
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/tools/tsconfig.lib.json --noEmit"
      },
      "cache": true
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "cache": true
    }
  }
}
