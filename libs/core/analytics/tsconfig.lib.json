{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",

    /* 🛡️ SANACIÓN DE CACHÉ (Zero Local Artifacts) */
    "outDir": "../../../dist/out-tsc/libs/core/analytics",
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/core/analytics/tsconfig.lib.tsbuildinfo",

    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,

    /* Estándar de Alto Rendimiento Next.js 15+ */
    "module": "Preserve",
    "moduleResolution": "bundler",
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,

    "lib": ["DOM", "DOM.Iterable", "ES2022"]
  },
  "include": ["src/**/*.ts", "src/**/*.json"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts", "jest.config.ts"],
  "references": [
    {
      "path": "../telemetry/tsconfig.lib.json"
    }
  ]
}
