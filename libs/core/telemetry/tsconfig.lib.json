{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /**
     * @section Gobernanza de Emisión - ISO Technical Rigor
     * Protocolo OEDP-V17.0 - Build Resilience & Forensic Traceability.
     */
    "outDir": "../../../dist/out-tsc/libs/core/telemetry",
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/core/telemetry/tsconfig.lib.tsbuildinfo",

    /**
     * @section Aislamiento Soberano (rootDir Enforcement)
     * SANEADO: Se establece 'src' como raíz absoluta y se bloquea la emisión de JS.
     * TSC actúa exclusivamente como el arquitecto de ADN del sistema nervioso.
     */
    "rootDir": "src",
    "noEmit": false,
    "emitDeclarationOnly": true,

    /**
     * @section Integridad del Grafo (Project References)
     * SANEADO: Sincronizado para permitir resolución de tipos instantánea
     * sin contaminación de ámbitos externos.
     */
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,

    /**
     * @section Resolución Next-Gen (Turbopack / Next.js 16+)
     * 🛡️ PURGA DE CRONOLOGÍA APLICADA.
     * Activación estricta de Verbatim Syntax para aislamiento lógico.
     */
    "module": "Preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    "types":["node"],
    "lib": ["DOM", "DOM.Iterable", "ES2022"]
  },

  /**
   * @section Alcance de Auditoría Atómica
   */
  "include":[
    "src/**/*.ts",
    "src/**/*.json"
  ],

  /**
   * @section Aduana de Exclusión (Anti-Contamination)
   * SANEADO: Bloqueo físico estricto de cualquier rastro volátil o externo.
   */
  "exclude":[
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "jest.config.ts",
    "dist",
    "out-tsc",
    "node_modules",
    "../../../dist",
    "../../../node_modules"
  ]
}