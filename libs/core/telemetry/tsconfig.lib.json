{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /* --- ESTRATÉGIA DE SAÍDA ZENITH --- */
    "outDir": "../../../dist/out-tsc/libs/core/telemetry",
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/core/telemetry/tsconfig.lib.tsbuildinfo",

    /* --- INTEGRIDADE SOBERANA (ADN Emitter) --- */
    "composite": true,           /* Habilita a participação no Grafo Incremental */
    "declaration": true,         /* Emite as assinaturas de tipos (.d.ts) vitais */
    "declarationMap": true,      /* Mapeamento para DX forense no IDE */
    "emitDeclarationOnly": true, /* O motor SWC cuida da lógica; TSC valida o ADN */
    "rootDir": "src",            /* Blindagem de fronteira física (Fix TS6059) */

    /*
     * 🛡️ MANOBRA DE ISOLAMENTO (OEDP-V17.0)
     * Resetamos os 'paths' para obrigar o compilador a usar as 'references'
     * e os arquivos .d.ts das dependências (ex: exceptions),
     * impedindo a sucção de código fonte externo.
     */
    "paths": {},

    /* --- RESOLUÇÃO NEXT-GEN (Standard Next.js 16) --- */
    "module": "Preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true, /* Separação estrita entre ADN e Lógica */
    "isolatedModules": true,

    /* --- ADN DO AMBIENTE (System Nervous Context) --- */
    "types": ["node"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },

  /* --- ESCOPO DE AUDITORIA ATÔMICA --- */
  "include": [
    "src/**/*.ts",
    "src/**/*.json"
  ],

  /* --- ADUANA DE EXCLUSÃO (Anti-Contamination) --- */
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "jest.config.ts",
    "dist",
    "out-tsc",
    "node_modules",
    /* 🛡️ SANEADO Zenith: Bloqueio físico para forçar o uso de referências de projeto */
    "../../../dist",
    "../../../node_modules"
  ]
}
