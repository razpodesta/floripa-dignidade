{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /* --- ESTRATEGIA DE SALIDA ZENITH (Out-of-Source) --- */
    "outDir": "../../../dist/out-tsc/libs/core/telemetry",
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/core/telemetry/tsconfig.lib.tsbuildinfo",

    /* --- INTEGRIDAD SOBERANA (ADN Emitter) --- */
    "composite": true,           /* Habilita la participación en el Grafo Incremental */
    "declaration": true,         /* Emite las firmas de tipos (.d.ts) para el enjambre */
    "declarationMap": true,      /* DX: Mapeo para salto al código fuente en el IDE */
    "emitDeclarationOnly": true, /* El motor SWC cuida la lógica; TSC valida la pureza del ADN */
    "rootDir": "src",            /* Blindaje de frontera física absoluta (Fix TS6059) */

    /**
     * 🛡️ MANOBRA DE REDIRECCIÓN DE ADN (OEDP-V17.0)
     * Sobreescribimos los paths globales para obligar al compilador a usar
     * las declaraciones (.d.ts) en lugar de succionar código fuente externo.
     * Esto extingue el error TS6059 de forma definitiva.
     */
    "paths": {
      "@floripa-dignidade/exceptions": ["../../../dist/out-tsc/libs/core/exceptions/src/index.d.ts"]
    },

    /* --- RESOLUCIÓN NEXT-GEN (Standard Next.js 16 & Turbopack) --- */
    "module": "Preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true, /* Fuerza la separación estricta entre tipos y lógica */
    "isolatedModules": true,

    /* --- ADN DEL ENTORNO (System Nervous Context) --- */
    "types": ["node"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },

  /* --- ESCOPO DE AUDITORÍA ATÔMICA --- */
  "include": [
    "src/**/*.ts",
    "src/**/*.json"
  ],

  /* --- ADUANA DE EXCLUSIÓN (Anti-Contamination) --- */
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "jest.config.ts",
    "dist",
    "out-tsc",
    "node_modules",
    /* 🛡️ SANEADO Zenith: Bloqueo de directorios de salida para evitar redundancia */
    "../../../dist",
    "../../../node_modules"
  ]
}
