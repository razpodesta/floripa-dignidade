{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc/libs/core/routing",
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/core/routing/tsconfig.lib.tsbuildinfo",

    /* --- INTEGRIDAD SOBERANA (ADN Emitter) --- */
    "composite": true,           /* Permite la compilación incremental del grafo */
    "declaration": true,         /* Emite las firmas de tipos (.d.ts) */
    "declarationMap": true,      /* Mapeo para trazabilidad en el IDE */
    "emitDeclarationOnly": true, /* Delega la lógica de ejecución a SWC */
    "rootDir": "src",            /* Blindaje de frontera física */

    /* --- RESOLUCIÓN NEXT-GEN (Next.js 16 Ready) --- */
    "module": "Preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true, /* Fuerza la separación estricta entre tipos y lógica */
    "isolatedModules": true,

    /* --- ADN DEL ENTORNO (Edge Runtime Context) --- */
    "types": ["node"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"] /* Necesario para Headers, Requests y Web Crypto */
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.json"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "jest.config.ts",
    "dist",
    "out-tsc",
    "node_modules",
    "../../../dist",
    "../../../node_modules"
  ]
}
