{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc/libs/core/exceptions",
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/core/exceptions/tsconfig.lib.tsbuildinfo",

    /**
     * 🛡️ EMITTER: Configuración activa de emisión de ADN.
     * Se desactiva noEmit para obligar a TSC a generar las firmas físicas.
     */
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "rootDir": "src",

    "module": "Preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    "types": [],
    "lib":["ES2022", "DOM", "DOM.Iterable"]
  },
  "include":[
    "src/**/*.ts",
    "src/**/*.json"
  ],
  "exclude":[
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "jest.config.ts",
    "dist",
    "out-tsc",
    "node_modules",
    "../../../dist",
    "../../../node_modules"
  ]
}
