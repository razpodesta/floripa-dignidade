{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc/libs/core/exceptions",
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/core/exceptions/tsconfig.lib.tsbuildinfo",

    /**
     * @section Resolución de Próxima Generación
     * SANEADO: Alineación con 'module: Preserve' y 'moduleResolution: bundler'.
     * Esta es la clave definitiva para sanar el error TS2307 en la App.
     */
    "module": "Preserve",
    "moduleResolution": "bundler",

    /**
     * Garantiza que cada archivo sea transpilado de forma independiente,
     * optimizando el rendimiento de SWC en el monorepo.
     */
    "isolatedModules": true,

    "types": [],
    "lib": ["DOM", "DOM.Iterable", "ES2022"]
  },
  "include": ["src/**/*.ts", "src/**/*.json"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "jest.config.ts",
    "dist",
    "out-tsc"
  ]
}
