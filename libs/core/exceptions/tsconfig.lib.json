{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc/libs/core/exceptions",
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/core/exceptions/tsconfig.lib.tsbuildinfo",

    /* --- INTEGRIDAD SOBERANA (ADN Emitter) --- */
    "composite": true,           /* Habilita la compilación incremental en el grafo */
    "declaration": true,         /* Emite las firmas de tipos (.d.ts) */
    "declarationMap": true,      /* Mapeo para depuración en el IDE */
    "emitDeclarationOnly": true, /* Delega la lógica a SWC/Turbopack */
    "rootDir": "src",            /* Blindaje de frontera física */

    /* --- RESOLUCIÓN NEXT-GEN (Next.js 16 Ready) --- */
    "module": "Preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true, /* Fuerza la pureza de importación de tipos */
    "isolatedModules": true,

    /* --- ADN DEL ENTORNO --- */
    "types": [],
    "lib": ["ES2022"]
  },
  "include": ["src/**/*.ts", "src/**/*.json"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "jest.config.ts",
    "dist",
    "out-tsc",
    "node_modules",
    "../../../dist",
    "../../../node_modules"
  ]
}
