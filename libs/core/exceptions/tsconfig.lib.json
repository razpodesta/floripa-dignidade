{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /**
     * @section Gobernanza de Emisión - ISO Technical Rigor
     * Protocolo OEDP-V16.0 - Build Resilience.
     */
    "outDir": "../../../dist/out-tsc/libs/core/exceptions",
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/core/exceptions/tsconfig.lib.tsbuildinfo",

    /**
     * @section Aislamiento Soberano (rootDir Enforcement)
     * SANEADO: Se establece 'src' como la raíz física absoluta.
     * Esto impide el error TS6059 al garantizar que el compilador no capture
     * archivos fuera de la frontera de lógica (como los archivos en 'dist').
     */
    "rootDir": "src",

    /**
     * @section Integridad del Grafo (Project References)
     * SANEADO: Se activa 'composite' para que Nx y TypeScript puedan
     * validar el rastro de tipos sin necesidad de recompilar la lógica fuente
     * en cada búnker consumidor.
     */
    "composite": true,
    "declaration": true,
    "declarationMap": true,

    /** Purificación de tipos globales para entornos isomórficos. */
    "types": [],
    "lib": ["DOM", "DOM.Iterable", "ES2022"]
  },

  /**
   * @section Alcance de Auditoría
   */
  "include": ["src/**/*.ts", "src/**/*.json"],

  /**
   * @section Aduana de Exclusión (Anti-Contamination)
   * SANEADO: Bloqueo físico de carpetas de salida y dependencias externas
   * para asegurar una compilación atómica y libre de rastro antiguo.
   */
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "jest.config.ts",
    "dist",
    "out-tsc",
    "../../../dist",
    "../../../node_modules"
  ]
}
