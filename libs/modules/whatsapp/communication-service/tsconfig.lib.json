{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../../dist/out-tsc/libs/modules/whatsapp/communication-service",
    "tsBuildInfoFile": "../../../../dist/out-tsc/libs/modules/whatsapp/communication-service/tsconfig.lib.tsbuildinfo",

    /**
     * @section Resolución de Próxima Generación
     * SANEADO: Erradicación de 'NodeNext' en favor de 'bundler' para permitir
     * el uso de 'Clean Paths' (importaciones sin extensiones .js).
     */
    "module": "Preserve",
    "moduleResolution": "bundler",

    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,

    /** Soporte para APIs criptográficas y de sistema de Node.js. */
    "types": ["node"],

    "lib": ["ES2022"]
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "jest.config.ts",
    "dist",
    "out-tsc"
  ]
}
