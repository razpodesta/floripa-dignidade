{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../../dist/out-tsc/libs/modules/whatsapp/communication-service",
    "tsBuildInfoFile": "../../../../dist/out-tsc/libs/modules/whatsapp/communication-service/tsconfig.lib.tsbuildinfo",
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": "src",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    /* 🛡️ SANEADO Zenith: Redirección de Grafo para evitar TS6059 */
    "paths": {
      "@floripa-dignidade/telemetry": ["../../../../dist/out-tsc/libs/core/telemetry/src/index.d.ts"],
      "@floripa-dignidade/exceptions": ["../../../../dist/out-tsc/libs/core/exceptions/src/index.d.ts"],
      "@floripa-dignidade/environment-validator": ["../../../../dist/out-tsc/libs/core/environment-validator/src/index.d.ts"]
    },

    "types": ["node"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["src/**/*.ts", "src/**/*.json"],
  "exclude": ["src/**/*.spec.ts", "dist", "out-tsc", "node_modules", "../../../../dist"]
}
