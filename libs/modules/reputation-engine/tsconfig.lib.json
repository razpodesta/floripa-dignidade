/**
 * @section tsconfig: Emitter (Reputation Engine)
 * @description Generador de ADN (.d.ts) con redirección física de Grafo.
 * Protocolo OEDP-V17.0 - Zenith Architecture Standard.
 * SANEADO Zenith: Redirección aplanada (Flattened) para erradicar TS2307.
 */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc/libs/modules/reputation-engine",
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/modules/reputation-engine/tsconfig.lib.tsbuildinfo",
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": "src",
    "noEmit": false,
    "importHelpers": true,

    /* --- REDIRECCIÓN DE ADN (SANEADO) --- */
    "paths": {
      "@floripa-dignidade/telemetry": ["../../../dist/out-tsc/libs/core/telemetry/index.d.ts"],
      "@floripa-dignidade/exceptions": ["../../../dist/out-tsc/libs/core/exceptions/index.d.ts"],
      "@floripa-dignidade/health-analysis-engine": ["../../../dist/out-tsc/libs/engines/health-analysis/index.d.ts"]
    },

    "module": "Preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    "types": ["node"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["src/**/*.ts", "src/**/*.json"],
  "exclude": ["dist", "out-tsc", "node_modules", "../../../dist", "../../../node_modules"],
  "references": [
    { "path": "../../core/exceptions/tsconfig.lib.json" },
    { "path": "../../core/telemetry/tsconfig.lib.json" },
    { "path": "../../engines/health-analysis/tsconfig.lib.json" }
  ]
}
