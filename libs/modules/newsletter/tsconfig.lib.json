{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc/libs/modules/newsletter",
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/modules/newsletter/tsconfig.lib.tsbuildinfo",

    /**
     * @section Resolución de Próxima Generación
     * SANEADO: Alineación con el estándar 'bundler' para sanar errores TS2307.
     */
    "module": "Preserve",
    "moduleResolution": "bundler",

    /**
     * @section Rigor de Transpilación
     * SANEADO: Inyección de 'isolatedModules' para garantizar que SWC/Turbopack
     * procesen cada átomo de lógica sin ambigüedades.
     */
    "isolatedModules": true,

    /** Soporte soberano para 'process.env' en búnkeres de lógica. */
    "types": ["node"],

    "lib": ["DOM", "DOM.Iterable", "ES2022"]
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "jest.config.ts",
    "dist",
    "out-tsc"
  ]
}
