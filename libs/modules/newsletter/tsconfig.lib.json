{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc/libs/modules/newsletter",
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/modules/newsletter/tsconfig.lib.tsbuildinfo",

    /* --- INTEGRIDAD SOBERANA (ADN Emitter) --- */
    "composite": true,           /* Habilita la compilación incremental y el grafo de referencias */
    "declaration": true,         /* Emite las firmas de tipos (.d.ts) para el Portal y CMS */
    "declarationMap": true,      /* Mapeo para trazabilidad forense en el IDE */
    "emitDeclarationOnly": true, /* Delega la lógica de ejecución al motor SWC/Turbopack */
    "rootDir": "src",            /* Blindaje de frontera física absoluta (Fix TS6059) */

    /* --- RESOLUCIÓN NEXT-GEN (Next.js 16 Ready) --- */
    "module": "Preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true, /* Fuerza la separación estricta entre tipos y lógica */
    "isolatedModules": true,

    /* --- ADN DEL ENTORNO (Cloud-Native Context) --- */
    "types": ["node"],
    "lib": ["DOM", "DOM.Iterable", "ES2022"] /* Soporte para fetch, performance y manejo de correos */
  },
  "include": ["src/**/*.ts", "src/**/*.json"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "jest.config.ts",
    "dist",
    "out-tsc",
    "node_modules",
    "../../../dist",
    "../../../node_modules"
  ]
}
