/**
 * @section tsconfig: Emitter
 * @description Generador de ADN (.d.ts) para el motor territorial.
 * Protocolo OEDP-V17.0 - Zenith Architecture Standard.
 */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc/libs/modules/territorial-engine",
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/modules/territorial-engine/tsconfig.lib.tsbuildinfo",

    /* --- Integridad Soberana --- */
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "rootDir": "src",
    "noEmit": false,
    "importHelpers": true,

    /* --- Redireccion de ADN (Solucion TS6059 / TS6305) --- */
    "paths": {
      "@floripa-dignidade/telemetry": ["../../../dist/out-tsc/libs/core/telemetry/index.d.ts"],
      "@floripa-dignidade/exceptions": ["../../../dist/out-tsc/libs/core/exceptions/index.d.ts"],
      "@floripa-dignidade/environment-validator": ["../../../dist/out-tsc/libs/core/environment-validator/index.d.ts"]
    },

    /* --- Resolucion Next-Gen --- */
    "module": "Preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    /* --- ADN del Entorno --- */
    "types": [],
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["src/**/*.ts", "src/**/*.json"],
  "exclude": [
    "src/**/*.spec.ts",
    "dist",
    "out-tsc",
    "node_modules",
    "../../../dist",
    "../../../node_modules"
  ],
  "references": [
    { "path": "../../core/environment-validator/tsconfig.lib.json" },
    { "path": "../../core/telemetry/tsconfig.lib.json" },
    { "path": "../../core/exceptions/tsconfig.lib.json" }
  ]
}
