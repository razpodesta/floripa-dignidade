/**
 * @section tsconfig: Emitter (Identity IAM)
 * @description Generador de ADN (.d.ts) para el Juez de Paz del ecosistema.
 * Protocolo OEDP-V17.0 - Zenith Architecture Standard.
 * SANEADO Zenith: Redireccion fisica aplanada para evitar TS6059.
 */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc/libs/modules/identity",
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/modules/identity/tsconfig.lib.tsbuildinfo",

    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "rootDir": "src",
    "noEmit": false,
    "importHelpers": true,

    /* --- REDIRECCIÓN DE ADN MAESTRO --- */
    "paths": {
      "@floripa-dignidade/exceptions": ["../../../dist/out-tsc/libs/core/exceptions/index.d.ts"],
      "@floripa-dignidade/telemetry": ["../../../dist/out-tsc/libs/core/telemetry/index.d.ts"],
      "@floripa-dignidade/environment-validator": ["../../../dist/out-tsc/libs/core/environment-validator/index.d.ts"]
    },

    "module": "Preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    "types": ["node"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["src/**/*.ts", "src/**/*.json"],
  "exclude": [
    "src/**/*.spec.ts",
    "dist",
    "out-tsc",
    "node_modules",
    "../../../dist",
    "../../../node_modules"
  ],
  "references": [
    { "path": "../../core/exceptions/tsconfig.lib.json" },
    { "path": "../../core/telemetry/tsconfig.lib.json" },
    { "path": "../../core/environment-validator/tsconfig.lib.json" }
  ]
}
