{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc/libs/modules/pmf-open-data-engine",
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/modules/pmf-open-data-engine/tsconfig.lib.tsbuildinfo",

    /* --- INTEGRIDAD SOBERANA (ADN Emitter) --- */
    "composite": true,           /* Habilita la compilación incremental y el grafo de referencias */
    "declaration": true,         /* Emite las firmas de tipos (.d.ts) para el Portal y Analítica */
    "declarationMap": true,      /* Mapeo para trazabilidad forense en el IDE */
    "emitDeclarationOnly": true, /* Delega la lógica de ejecución al motor SWC/Turbopack */
    "rootDir": "src",            /* Blindaje de frontera física absoluta (Fix TS6059) */

    /* --- RESOLUCIÓN NEXT-GEN (Next.js 16 Ready) --- */
    "module": "Preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true, /* Fuerza la separación estricta entre tipos y lógica */
    "isolatedModules": true,

    /* --- ADN DEL ENTORNO (Data Extraction Context) --- */
    "types": ["node"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"] /* Soporte para fetch, crypto-digest y procesos asíncronos */
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.json"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "jest.config.ts",
    "dist",
    "out-tsc",
    "node_modules",
    "../../../dist",
    "../../../node_modules"
  ]
}
