{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc/libs/modules/interaction-engine",
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/modules/interaction-engine/tsconfig.lib.tsbuildinfo",

    /* --- INTEGRIDAD SOBERANA (ADN Emitter) --- */
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "rootDir": "src",

    /* 🛡️ SANEADO Zenith: Redirección de Grafo (Fix TS6059 / TS6307) */
    "paths": {
      "@floripa-dignidade/shared":["../../../dist/out-tsc/libs/shared/src/index.d.ts"]
    },

    /* --- RESOLUCIÓN NEXT-GEN (Next.js 16 Ready) --- */
    "module": "Preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    /* --- ADN DEL ENTORNO (Isomorphic Interaction Context) --- */
    "types":[],
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include":["src/**/*.ts", "src/**/*.json"],
  "exclude":[
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "jest.config.ts",
    "dist",
    "out-tsc",
    "node_modules",
    "../../../dist",
    "../../../node_modules"
  ]
}
