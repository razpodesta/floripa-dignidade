{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",

    /* 🛡️ SANACIÓN DE CACHÉ (Zero Local Artifacts)
       Desviamos la basura de compilación de TSC a la raíz del monorepo.
       Evita la polución visual y posibles conflictos de resolución con Turbopack. */
    "outDir": "../../../dist/out-tsc/libs/engines/health-analysis",
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/engines/health-analysis/tsconfig.lib.tsbuildinfo",

    /* Protocolo de Proyecto Compuesto (Project References) */
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,

    /* Estándar de Alto Rendimiento Next.js 15+ / Turbopack */
    "module": "Preserve",
    "moduleResolution": "bundler",
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,

    "types": [],
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.json"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "jest.config.ts"
  ],
  "references": [
    {
      "path": "../../core/telemetry/tsconfig.lib.json"
    }
  ]
}
