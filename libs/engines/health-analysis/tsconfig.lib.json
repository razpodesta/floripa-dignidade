{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc/libs/engines/health-analysis",
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/engines/health-analysis/tsconfig.lib.tsbuildinfo",

    /* --- INTEGRIDAD SOBERANA (ADN Emitter) --- */
    "composite": true,           /* Habilita la compilación incremental del motor de IA */
    "declaration": true,         /* Emite las firmas de tipos (.d.ts) para el resto del enjambre */
    "declarationMap": true,      /* Mapeo para depuración cognitiva en el IDE */
    "emitDeclarationOnly": true, /* Delega la lógica de ejecución al motor SWC/Turbopack */
    "rootDir": "src",            /* Blindaje de frontera física absoluta */

    /* --- RESOLUCIÓN NEXT-GEN (Next.js 16 Ready) --- */
    "module": "Preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true, /* Fuerza la separación estricta entre tipos y lógica */
    "isolatedModules": true,

    /* --- ADN DEL ENTORNO (Isomorphic AI Context) --- */
    "types": [],
    "lib": ["DOM", "DOM.Iterable", "ES2022", "WebWorker"] /* Soporte para fetch y procesamiento asíncrono */
  },
  "include": ["src/**/*.ts", "src/**/*.json"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "jest.config.ts",
    "dist",
    "out-tsc",
    "node_modules",
    "../../../dist",
    "../../../node_modules"
  ]
}
