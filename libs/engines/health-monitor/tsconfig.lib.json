{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",

    /* 🛡️ SANACIÓN DE CACHÉ (Zero Local Artifacts)
       Redirección de metadatos de compilación hacia la raíz del monorepo.
       Mantiene la pureza del búnker, evitando carpetas 'dist' intrusas. */
    "outDir": "../../../dist/out-tsc/libs/engines/health-monitor",
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/engines/health-monitor/tsconfig.lib.tsbuildinfo",

    /* Protocolo de Proyecto Compuesto (Project References) */
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,

    /* Estándar de Alto Rendimiento Next.js 15+ / Turbopack */
    "module": "Preserve",
    "moduleResolution": "bundler",
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,

    /* Soporte para lógica de servidor (SRE Pings) */
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "src/**/*.json"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts", "jest.config.ts"],
  "references": [
    {
      "path": "../../core/exceptions/tsconfig.lib.json"
    },
    {
      "path": "../../core/telemetry/tsconfig.lib.json"
    }
  ]
}
