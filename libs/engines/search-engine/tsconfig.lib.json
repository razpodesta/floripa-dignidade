{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc/libs/engines/search-engine",
    "tsBuildInfoFile": "../../../dist/out-tsc/libs/engines/search-engine/tsconfig.lib.tsbuildinfo",

    /* --- INTEGRIDAD SOBERANA (ADN Emitter) --- */
    "composite": true,           /* Habilita la compilación incremental del motor de descubrimiento */
    "declaration": true,         /* Emite las firmas de tipos (.d.ts) para el enjambre */
    "declarationMap": true,      /* Mapeo para trazabilidad en el IDE */
    "emitDeclarationOnly": true, /* Delega la lógica de ejecución al motor SWC */
    "rootDir": "src",            /* Blindaje de frontera física absoluta */

    /* --- RESOLUCIÓN NEXT-GEN (Turbopack Ready) --- */
    "module": "Preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true, /* Fuerza la separación estricta entre tipos y lógica */
    "isolatedModules": true,

    /* --- ADN DEL ENTORNO (Isomorphic Discovery Context) --- */
    "types": [],
    "lib": ["ES2022", "DOM", "DOM.Iterable"] /* Necesario para la interoperabilidad de Fuse.js */
  },
  "include": ["src/**/*.ts", "src/**/*.json"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "jest.config.ts",
    "dist",
    "out-tsc",
    "node_modules",
    "../../../dist",
    "../../../node_modules"
  ]
}
