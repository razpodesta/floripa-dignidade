/**
 * @section tsconfig: Emitter
 * @description Generador de ADN (.d.ts) para la fundicion visual.
 * Protocolo OEDP-V17.0 - Zenith Architecture Standard.
 */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc/libs/shared",
    "tsBuildInfoFile": "../../dist/out-tsc/libs/shared/tsconfig.lib.tsbuildinfo",

    /* --- Integridad Soberana --- */
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "rootDir": "src",
    "noEmit": false,
    "importHelpers": true,

    /* --- Redireccion de ADN (Solucion TS6059 / TS6305) --- */
    "paths": {
      "@floripa-dignidade/telemetry": ["../../dist/out-tsc/libs/core/telemetry/index.d.ts"],
      "@floripa-dignidade/exceptions": ["../../dist/out-tsc/libs/core/exceptions/index.d.ts"]
    },

    /* --- Gobernanza de Renderizado --- */
    "jsx": "react-jsx",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    /* --- ADN del Entorno (Web Context) --- */
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": []
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.json"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "jest.config.ts",
    "dist",
    "out-tsc",
    "node_modules",
    "../../dist",
    "../../node_modules"
  ],
  "references": [
    { "path": "../core/exceptions/tsconfig.lib.json" },
    { "path": "../core/telemetry/tsconfig.lib.json" }
  ]
}
