{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc/libs/shared",
    "tsBuildInfoFile": "../../dist/out-tsc/libs/shared/tsconfig.lib.tsbuildinfo",

    /* --- INTEGRIDAD SOBERANA (ADN Emitter) --- */
    "composite": true,           /* Habilita la compilación incremental de la fundição visual */
    "declaration": true,         /* Emite las firmas de tipos (.d.ts) para el Portal y CMS */
    "declarationMap": true,      /* Mapeo para trazabilidad de componentes en el IDE */
    "emitDeclarationOnly": true, /* Delega la lógica de ejecución al motor SWC/Turbopack */
    "rootDir": "src",            /* Blindaje de frontera física absoluta (Fix TS6059) */

    /* --- GOBERNANZA DE RENDERIZADO (React 19 / Next.js 16) --- */
    "jsx": "react-jsx",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true, /* Fuerza la separación estricta entre ADN y Lógica */
    "isolatedModules": true,

    /* --- ADN DEL ENTORNO (Visual & State Context) --- */
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": []
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.json"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "jest.config.ts",
    "dist",
    "out-tsc",
    "node_modules",
    "../../dist",
    "../../node_modules"
  ]
}
