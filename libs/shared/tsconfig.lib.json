{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",

    /* 🛡️ SANACIÓN DE CACHÉ (Zero Local Artifacts)
       Redirección de metadatos de compilación hacia la raíz del monorepo.
       Garantiza que el búnker visual permanezca inmaculado. */
    "outDir": "../../dist/out-tsc/libs/shared",
    "tsBuildInfoFile": "../../dist/out-tsc/libs/shared/tsconfig.lib.tsbuildinfo",

    /* Protocolo de Proyecto Compuesto (Project References) */
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,

    /* Estándar de Alto Rendimiento Next.js 15+ / Turbopack */
    "module": "Preserve",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,

    /* Librerías de ejecución: Soporte para DOM y estándares modernos */
    "lib": ["DOM", "DOM.Iterable", "ES2022"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.json"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts", "jest.config.ts"],
  "references": [
    {
      "path": "../core/telemetry/tsconfig.lib.json"
    }
  ]
}
